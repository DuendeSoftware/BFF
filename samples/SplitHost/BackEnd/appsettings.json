{
  "ReverseProxy": {
    "Routes": {
      "FrontEndRoute": {
        "ClusterId": "FrontEndCluster",
        "Match": {
          "Path": "/app/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/app" }
        ]
      }
    },
    "Clusters": {
      "FrontEndCluster": {
        "Destinations": {
          "FrontEndServer": {
            "Address": "https://localhost:5003/"
          }
        }
      }
    }
  },
  //Sets the Logging level for ASP.NET
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      // Uncomment to hide diagnostic messages from runtime and proxy
      // "Microsoft": "Warning",
      // "Yarp" : "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}